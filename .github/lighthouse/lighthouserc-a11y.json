{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "settings": {
        "onlyCategories": ["accessibility"],
        "formFactor": "desktop",
        "screenEmulation": {
          "mobile": false,
          "width": 1350,
          "height": 940,
          "deviceScaleFactor": 1,
          "disabled": false
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["warn", { "minScore": 0.7 }],
        "aria-allowed-attr": "warn",
        "aria-hidden-body": "error",
        "aria-hidden-focus": "warn",
        "aria-required-attr": "warn",
        "aria-roles": "warn",
        "aria-valid-attr-value": "warn",
        "aria-valid-attr": "warn",
        "button-name": "warn",
        "color-contrast": "off",
        "document-title": "warn",
        "duplicate-id-active": "warn",
        "duplicate-id-aria": "warn",
        "html-has-lang": "warn",
        "html-lang-valid": "warn",
        "image-alt": "warn",
        "label": "warn",
        "link-name": "warn",
        "list": "warn",
        "meta-viewport": "warn",
        "tabindex": "warn",
        "valid-lang": "warn"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
